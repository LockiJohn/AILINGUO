{
    "compilerOptions": {
        "composite": true,
        "skipLibCheck": true,
        "module": "CommonJS",
        "moduleResolution": "node",
        "target": "ES2020",
        "rootDir": "electron",
        "outDir": "dist-electron",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "strict": false,
        "noUnusedLocals": false
    },
    "include": [
        "electron"
    ]
}