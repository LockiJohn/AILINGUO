                },
                {
                    "type": "multiple_choice",
                    "prompt_it": "Qual è l'orario corretto in inglese per le 3 del pomeriggio?",
                    "audio_text": "It's three o'clock.",
                    "options": [
                        "It's three o'clock.",
                        "It's the three.",
                        "It's at three.",
                        "It are three."
                    ],
                    "correct_answer": "It's three o'clock.",
                    "explanation_it": "Per dire l'ora in inglese: 'It's [numero] o'clock'. 'O'clock' significa '...in punto'.",
                    "grammar_rule": "It's [hour] o'clock = Sono le [ora] in punto",
