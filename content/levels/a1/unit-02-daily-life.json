                {
                    "type": "fill_blank",
                    "prompt_en": "Every morning I _____ breakfast at 8 o'clock.",
                    "prompt_it": "Completa: ogni mattina faccio colazione alle 8",
                    "correct_answer": "eat",
                    "explanation_it": "'eat breakfast' = fare colazione. In inglese si dice letteralmente 'mangiare la colazione'.",
