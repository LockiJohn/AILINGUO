                    "prompt_it": "Come chiedi il nome a qualcuno in inglese?",
                    "audio_text": "What's your name?",
                    "options": [
                        "What's your name?",
                        "How are you?",
                        "Where are you?",
                        "Who are you?"
                    ],
                    "correct_answer": "What's your name?",
                    "explanation_it": "'What's your name?' = 'Come ti chiami?'. 'What's' è la contrazione di 'What is'.",
                    "grammar_rule": "What is = What's (contrazione)",
                    "difficulty": 1
                },
                {
                    "type": "translation_it_en",
                    "prompt_it": "Traduci: Mi chiamo Marco.",
                    "audio_text": "My name is Marco.",
                    "correct_answer": "My name is Marco.",
                    "explanation_it": "In inglese NON si dice 'I call myself Marco'. La struttura corretta è 'My name is [nome]'.",
                    "grammar_rule": "My name is = Mi chiamo (letteralmente: Il mio nome è)",
                    "difficulty": 1
                },
                {
                    "type": "multiple_choice",
                    "prompt_it": "Come chiedi a qualcuno da dove viene?",
                    "audio_text": "Where are you from?",
                    "options": [
                        "Where are you from?",
                        "Who are you from?",
                        "What are you from?",
                        "How are you from?"
                    ],
                    "correct_answer": "Where are you from?",
                    "explanation_it": "'Where are you from?' = 'Da dove vieni?'. 'Where' significa 'dove'.",
                    "difficulty": 1
                },
                {
                    "type": "translation_it_en",
                    "prompt_it": "Traduci: Sono italiano.",
                    "audio_text": "I'm Italian.",
                    "correct_answer": "I'm Italian.",
                    "explanation_it": "In inglese le nazionalità si scrivono sempre con la maiuscola: Italian, French, Spanish...",
                    "grammar_rule": "Le nazionalità in inglese hanno sempre la maiuscola",
                    "difficulty": 1
                },
                {
                    "type": "fill_blank",
                    "prompt_en": "I'm _____ Italy. I live in Rome.",
                    "prompt_it": "Completa con la preposizione corretta:",
                    "correct_answer": "from",
                    "explanation_it": "'From' indica la provenienza. 'I'm from Italy' = 'Sono dell'Italia / Vengo dall'Italia'.",
                    "grammar_rule": "from = da (provenienza)",
                    "difficulty": 2
                },
                {
                    "type": "multiple_choice",
                    "prompt_it": "Come si dice 'Ho 30 anni' in inglese?",
                    "audio_text": "I'm 30 years old.",
                    "options": [
                        "I'm 30 years old.",
                        "I have 30 years.",
                        "I am 30 years.",
                        "I have 30 years old."
                    ],
                    "correct_answer": "I'm 30 years old.",
                    "explanation_it": "Errore classico degli italiani: in inglese NON si dice 'I have 30 years'. Si usa TO BE: 'I AM 30 years old'.",
                    "grammar_rule": "Età in inglese: I AM [numero] years old (non I HAVE [numero] years!)",
                    "difficulty": 2
                },
                {
                    "type": "word_order",
                    "prompt_it": "Riordina: 'Il mio nome è Sara e vengo dall'Italia'",
                    "options": [
                        "My",
                        "name",
                        "is",
                        "Sara",
                        "and",
                        "I'm",
                        "from",
                        "Italy"
                    ],
                    "correct_answer": "My name is Sara and I'm from Italy",
                    "explanation_it": "Struttura: My name is [nome] and I'm from [paese].",
                    "difficulty": 2
                },
                {
                    "type": "speaking",
                    "prompt_it": "Presentati in inglese (usa il tuo nome vero!):",
                    "audio_text": "Hello! My name is Michele. I'm from Italy. Nice to meet you!",
                    "correct_answer": "Hello! My name is Michele. I'm from Italy. Nice to meet you!",
                    "explanation_it": "Prova a dire il tuo vero nome e a sostituire 'Michele' con il tuo. Questa è la struttura base di una presentazione.",
                    "difficulty": 2
                }
            ]
        },
