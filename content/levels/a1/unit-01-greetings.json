            "exercises": [
                {
                    "type": "multiple_choice",
                    "prompt_it": "Come si dice 'Ciao' (informale) in inglese?",
                    "audio_text": "Hi",
                    "options": [
                        "Hi",
                        "Bye",
                        "Sorry",
                        "Please"
                    ],
                    "correct_answer": "Hi",
                    "explanation_it": "'Hi' è il saluto informale più comune in inglese, equivalente al nostro 'Ciao'.",
                    "difficulty": 1
                },
                {
                    "type": "multiple_choice",
                    "prompt_it": "Come si dice 'Buongiorno' in inglese?",
                    "audio_text": "Good morning",
                    "options": [
                        "Good morning",
                        "Good night",
                        "Good evening",
                        "Good afternoon"
                    ],
                    "correct_answer": "Good morning",
                    "explanation_it": "'Good morning' si usa al mattino (fino alle 12). 'Good afternoon' nel pomeriggio, 'Good evening' la sera.",
                    "difficulty": 1
                },
                {
                    "type": "translation_it_en",
                    "prompt_it": "Traduci in inglese: Buonasera",
                    "audio_text": "Good evening",
                    "correct_answer": "Good evening",
                    "explanation_it": "'Good evening' si usa la sera. Non confonderlo con 'Good night' che si dice solo quando si va a dormire.",
                    "difficulty": 1
                },
                {
                    "type": "multiple_choice",
                    "prompt_it": "Come si dice 'Arrivederci' in inglese?",
                    "audio_text": "Goodbye",
                    "options": [
                        "Goodbye",
                        "Hello",
                        "Thank you",
                        "Sorry"
                    ],
                    "correct_answer": "Goodbye",
                    "explanation_it": "'Goodbye' è il saluto formale di congedo. Informalmente puoi dire 'Bye' o 'See you'.",
                    "difficulty": 1
                },
                {
                    "type": "translation_en_it",
                    "prompt_en": "How are you?",
                    "audio_text": "How are you?",
                    "correct_answer": "Come stai?",
                    "explanation_it": "'How are you?' letteralmente 'Come sei?' si traduce con 'Come stai?'. Attenzione: non confondere 'how' (come) con 'what' (che cosa).",
                    "grammar_rule": "how = come | what = che cosa / qual",
                    "difficulty": 1
                },
                {
                    "type": "multiple_choice",
                    "prompt_en": "How do you answer 'How are you?' when you feel good?",
                    "audio_text": "I'm fine, thank you",
                    "options": [
                        "I'm fine, thank you",
                        "My name is Marco",
                        "I'm from Italy",
                        "See you later"
                    ],
                    "correct_answer": "I'm fine, thank you",
                    "explanation_it": "'I'm fine, thank you' significa 'Sto bene, grazie'. Puoi anche dire 'I'm great!' (ottimo) o 'Not bad' (non male).",
                    "difficulty": 1
                },
                {
                    "type": "word_order",
                    "prompt_it": "Riordina le parole per formare: 'Nice to meet you'",
                    "options": [
                        "you",
                        "nice",
                        "meet",
                        "to"
                    ],
                    "correct_answer": "nice to meet you",
                    "explanation_it": "'Nice to meet you' significa 'Piacere di conoscerti'. È la frase standard quando si incontra qualcuno per la prima volta.",
                    "difficulty": 1
                },
                {
                    "type": "listen_write",
                    "audio_text": "Good morning! How are you?",
                    "correct_answer": "Good morning! How are you?",
                    "explanation_it": "Questo è un saluto completo del mattino. 'Good morning' + 'How are you?' è la combinazione più comune.",
                    "difficulty": 2
                },
                {
                    "type": "speaking",
                    "prompt_it": "Pronuncia questa frase ad alta voce:",
                    "audio_text": "Hello, nice to meet you!",
                    "correct_answer": "Hello, nice to meet you!",
                    "explanation_it": "Fai attenzione alla pronuncia di 'nice' [naɪs] e 'meet' [miːt].",
                    "difficulty": 2
                },
                {
                    "type": "fill_blank",
                    "prompt_en": "Good _____, I'm John. Nice to meet you.",
                    "prompt_it": "Completa con il saluto del mattino:",
                    "correct_answer": "morning",
                    "explanation_it": "'Good morning' si usa dal risveglio fino a mezzogiorno.",
                    "difficulty": 1
                }
            ]
        },
